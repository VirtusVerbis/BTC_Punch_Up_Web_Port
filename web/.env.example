# Defaults mirror Android: direct production Binance WS + REST (`stream.binance.com:9443`, `api.binance.com`).
# Override only if you need testnet or a same-origin proxy:
# VITE_BINANCE_WS_URL=wss://stream.testnet.binance.vision/stream?streams=btcusdt@trade/btcusdt@ticker/btcusdt@bookTicker
# VITE_BINANCE_API_ORIGIN=https://testnet.binance.vision

VITE_COINBASE_PRODUCT_ID=BTC-USD
VITE_MEMPOOL_TIP_URL=https://mempool.space/api/blocks/tip/height

# Dev server proxies `/binance-api` → `VITE_BINANCE_API_ORIGIN` host (see vite.config.ts).
# Production: if the browser blocks CORS, point this at your same-origin proxy URL.
