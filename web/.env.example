# Dev: Binance/Coinbase websockets default to same-origin `/ws-binance` and `/ws-coinbase` (Vite proxies to upstream).
# Override with the vars below to connect directly from the browser instead.
# Binance: production default uses Spot Testnet (testnet.binance.vision) for WS + REST to reduce geo-blocking.
# Uncomment to force mainnet streams / API instead:
# VITE_BINANCE_WS_URL=wss://stream.binance.com:9443/stream?streams=btcusdt@trade/btcusdt@ticker/btcusdt@bookTicker
# VITE_BINANCE_API_ORIGIN=https://api.binance.com

VITE_COINBASE_PRODUCT_ID=BTC-USD
VITE_MEMPOOL_TIP_URL=https://mempool.space/api/blocks/tip/height

# Optional: override Binance REST origin (klines). Defaults to https://testnet.binance.vision.
# Dev server proxies /binance-api to the same host — see vite.config.ts.
# Production: if the browser blocks CORS, point this at your same-origin proxy URL.
